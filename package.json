{
  "name": "@mojis/moji-compare",
  "version": "0.5.0",
  "description": "Compare Emoji & Unicode versions",
  "type": "module",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "packageManager": "pnpm@10.22.0",
  "license": "MIT",
  "homepage": "https://github.com/mojisdev/moji-compare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mojisdev/moji-compare.git"
  },
  "bugs": {
    "url": "https://github.com/mojisdev/moji-compare/issues"
  },
  "keywords": [
    "semver",
    "version",
    "compare",
    "browser",
    "node",
    "emoji",
    "unicode"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "compare-versions": "6.1.1"
  },
  "devDependencies": {
    "@luxass/eslint-config": "4.19.0",
    "@types/node": "22.19.1",
    "@vitest/coverage-v8": "3.2.2",
    "eslint": "^9.23.0",
    "publint": "0.3.15",
    "tsdown": "0.16.4",
    "typescript": "5.9.3",
    "vitest": "3.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
